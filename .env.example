# busca-vzla — variables de entorno (todas OPCIONALES; defaults seguros = apagado)

# --- Fuentes oficiales ---
# Habilita el adapter de ReliefWeb (UN OCHA). Requiere un appname aprobado en
# apidoc.reliefweb.int. Sin esto, la fuente queda apagada.
RELIEFWEB_APPNAME=

# --- Partner: Puente VE (señales de zona anonimizadas) ---
# Base del proyecto Supabase de Puente VE y su anon key. Sin ambos, el adapter
# no ingiere nada. Además, en lib/agg/sources.ts hay que poner enabled: true.
PUENTE_VE_URL=
PUENTE_VE_ANON_KEY=

# --- Buscador de personas (PROXY) ---
# Interruptor maestro del buscador federado de personas. Por defecto APAGADO.
# Con "on": consulta a los finders elegibles (hoy: encuentralos, que consintió
# vía formulario) y muestra resultados DENTRO de la app, filtrados a
# {nombre, rango de edad, estado, enlace} — nunca cédula/teléfono/dirección.
# Incluye rate-limit en memoria (ok para un solo nodo/dev). Para producción a
# escala, configurar Upstash (rate-limit compartido) y Turnstile (anti-bot).
PERSON_SEARCH_PROXY=off
